# Byte-compiled / optimized
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Tooling caches
.ruff_cache/
.mypy_cache/
.pytest_cache/
.coverage
htmlcov/

# OS
.DS_Store

# Editors
.idea/
.vscode/

# Run outputs — keep the directory, ignore everything written into it.
# (CLAUDE.md §1: runs/ accumulates and is never hand-edited.)
/runs/*
!/runs/.gitkeep
